<Window x:Class="FileShelf.Win.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FileShelf"
        Width="430"
        Height="372"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF5F8FA">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FF2C739E" />
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="32"
                        Height="32"
                        Background="#FF2C739E"
                        CornerRadius="7">
                    <TextBlock Text="D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFFFF" />
                </Border>
                <StackPanel Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FF202326" />
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#FF73776F" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="12"
                    Background="#FFFFFFFF"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="VersionLabelTextBlock" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="VersionTextBlock" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="RuntimeLabelTextBlock" Grid.Row="1" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="RuntimeTextBlock" Grid.Row="1" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="ModeLabelTextBlock" Grid.Row="2" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="ModeTextBlock" Grid.Row="2" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="DataLabelTextBlock" Grid.Row="3" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="DataTextBlock" Grid.Row="3" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="LogLabelTextBlock" Grid.Row="4" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="LogTextBlock" Grid.Row="4" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="DevelopmentLabelTextBlock" Grid.Row="5" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Center" />
                    <TextBlock x:Name="DevelopmentTextBlock" Grid.Row="5" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="ScopeLabelTextBlock" Grid.Row="6" FontSize="11" Foreground="#FF73776F" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <TextBlock x:Name="ScopeTextBlock" Grid.Row="6" Grid.Column="1" FontSize="11" Foreground="#FF202326" VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Button x:Name="CloseButton"
                    Grid.Row="2"
                    Height="28"
                    MinWidth="78"
                    Margin="0,12,0,0"
                    Padding="12,0"
                    HorizontalAlignment="Right"
                    Style="{StaticResource ActionButton}"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
