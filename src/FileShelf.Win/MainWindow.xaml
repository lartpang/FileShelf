<Window x:Class="FileShelf.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FileShelf"
        Width="64"
        Height="64"
        MinWidth="1"
        MinHeight="1"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <Style x:Key="ShelfButton" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#0F000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF141414" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#18000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#26000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ItemActionButton" TargetType="Button" BasedOn="{StaticResource ShelfButton}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="8.5" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="MinWidth" Value="14" />
        </Style>

        <Style x:Key="ShelfScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShelfScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbSurface"
                                Width="6"
                                Margin="2"
                                Background="#66000000"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="#88000000" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="#AA000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border Margin="2,3"
                                    Background="#12000000"
                                    CornerRadius="5" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ShelfScrollBarPageButton}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ShelfScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ShelfScrollBarPageButton}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <Border x:Name="IconShell"
            Width="52"
            Height="52"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            CornerRadius="13"
            Cursor="Hand"
            ToolTip="FileShelf"
            MouseLeftButtonDown="IconShell_MouseLeftButtonDown"
            MouseLeftButtonUp="IconShell_MouseLeftButtonUp"
            MouseMove="IconShell_MouseMove"
            MouseRightButtonDown="IconShell_MouseRightButtonDown">
        <Grid>
            <Image x:Name="IconLogoImage"
                   Width="46"
                   Height="46"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
            <Border x:Name="IconDropHint"
                    Height="16"
                    Width="46"
                    Background="#EFFFFFFF"
                    BorderBrush="#66141414"
                    BorderThickness="1"
                    CornerRadius="7"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,5"
                    Visibility="Collapsed">
                <TextBlock x:Name="IconDropHintTextBlock"
                           FontSize="8.5"
                           Foreground="#FF141414"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>

    <Border x:Name="ShelfShell"
            Margin="10"
            CornerRadius="14"
            Visibility="Collapsed"
            Background="#F4FFFFFF"
            BorderBrush="#CC171717"
            BorderThickness="1"
            Padding="8">
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShelfSlideTransform" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="ShelfShadow"
                              BlurRadius="14"
                              ShadowDepth="2"
                              Direction="270"
                              Color="#55111111"
                              Opacity="0.35" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="8"
                    Background="#08000000"
                    PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown">
                <Grid Margin="8,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button x:Name="PanelPinButton"
                                Style="{StaticResource ItemActionButton}"
                                Content="&#xE718;"
                                Click="PanelPinButton_Click" />
                        <Button x:Name="CheckShelfButton"
                                Style="{StaticResource ItemActionButton}"
                                Content="&#xE9D5;"
                                Margin="4,0,0,0"
                                Click="CheckShelfButton_Click" />
                    </StackPanel>
                    <Border x:Name="CountDragHandle"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            MaxWidth="190"
                            Height="18"
                            Padding="3,0,7,0"
                            Background="#10000000"
                            CornerRadius="9"
                            Cursor="Hand"
                            MouseLeftButtonDown="CountText_MouseLeftButtonDown"
                            MouseLeftButtonUp="CountText_MouseLeftButtonUp"
                            MouseMove="CountText_MouseMove">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CountIconSurface"
                                    Width="14"
                                    Height="14"
                                    Background="#FFFFFFFF"
                                    CornerRadius="7"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CountIconText"
                                           Text="&#xE7C3;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="8.5"
                                           Foreground="#FF141414"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="CountText"
                                       Margin="5,0,0,0"
                                       FontSize="9.5"
                                       Foreground="#FF141414"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,6,0,0">
                <Border x:Name="DropTargetBorder"
                        Background="#FAFFFFFF"
                        BorderBrush="#1F000000"
                        BorderThickness="1"
                        CornerRadius="12"
                        MouseLeftButtonDown="ShelfBackground_MouseLeftButtonDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ListBox x:Name="ShelfList"
                                 ItemsSource="{Binding Items}"
                                 SelectionMode="Extended"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="7"
                                 SelectionChanged="ShelfList_SelectionChanged"
                                 KeyDown="ShelfList_KeyDown"
                                 PreviewMouseLeftButtonDown="ShelfList_PreviewMouseLeftButtonDown"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ItemSurface"
                                        MinHeight="38"
                                        Padding="5"
                                        Background="#FFFFFFFF"
                                        BorderBrush="#1F000000"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        MouseLeftButtonDown="FileItem_MouseLeftButtonDown"
                                        MouseMove="FileItem_MouseMove"
                                        MouseRightButtonUp="FileItem_MouseRightButtonUp">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="24"
                                              Height="24"
                                              VerticalAlignment="Center">
                                            <Border x:Name="GroupLayerBack"
                                                    Width="18"
                                                    Height="18"
                                                    Margin="5,1,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#FFEAEAEA"
                                                    CornerRadius="5"
                                                    Visibility="Collapsed" />
                                            <Border x:Name="GroupLayerMid"
                                                    Width="19"
                                                    Height="19"
                                                    Margin="3,3,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#FFF3F3F3"
                                                    CornerRadius="5"
                                                    Visibility="Collapsed" />
                                            <Border x:Name="BadgeSurface"
                                                    Width="22"
                                                    Height="22"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#FFFFFFFF"
                                                    BorderBrush="#33141414"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Visibility="{Binding BadgeVisibility}">
                                                <TextBlock x:Name="BadgeText"
                                                           Text="{Binding Badge}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="8"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF141414"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <Border x:Name="IconSurface"
                                                    Width="30"
                                                    Height="30"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#FFFFFFFF"
                                                    BorderBrush="#33141414"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Visibility="{Binding IconVisibility}">
                                                <Image Source="{Binding IconImage}"
                                                       Width="22"
                                                       Height="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Stretch="Uniform" />
                                            </Border>
                                        </Grid>
                                        <StackPanel x:Name="ItemTextPanel"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="3,0,5,0">
                                            <TextBlock x:Name="ItemNameText"
                                                       Text="{Binding Name}"
                                                       FontSize="9.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF141414"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="ItemPathText"
                                                       Text="{Binding PathSummary}"
                                                       Margin="0,0,0,0"
                                                       FontSize="8"
                                                       Foreground="#FF5A5A5A"
                                                       ToolTip="{Binding FullPathToolTip}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="MissingTextBlock"
                                                       Text="{Binding MissingText}"
                                                       Margin="0,0,0,0"
                                                       FontSize="8"
                                                       Foreground="#FF8A5A00"
                                                       Visibility="{Binding MissingVisibility}" />
                                            <TextBlock x:Name="VersionTextBlock"
                                                       Text="{Binding VersionText}"
                                                       Margin="0,0,0,0"
                                                       FontSize="8"
                                                       Foreground="#FF8A5A00"
                                                       Visibility="{Binding VersionVisibility}" />
                                        </StackPanel>
                                        <TextBlock x:Name="PinStatusText"
                                                   Grid.Column="2"
                                                   Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   Foreground="#88141414"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding PinToolTip}"
                                                   Visibility="Collapsed" />
                                        <StackPanel x:Name="ActionPanel"
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Opacity="0.68"
                                                    Visibility="Visible">
                                            <UniformGrid Rows="1"
                                                         Columns="3"
                                                         HorizontalAlignment="Right">
                                                <Button x:Name="PinItemButton"
                                                        Style="{StaticResource ItemActionButton}"
                                                        Content="&#xE718;"
                                                        ToolTip="{Binding PinToolTip}"
                                                        Click="PinItemButton_Click" />
                                                <Button x:Name="RevealItemButton"
                                                        Style="{StaticResource ItemActionButton}"
                                                        Content="&#xE8A7;"
                                                        ToolTip="{Binding RevealToolTip}"
                                                        Margin="2,0,0,0"
                                                        Click="RevealItemButton_Click" />
                                                <Button x:Name="RemoveItemButton"
                                                        Style="{StaticResource ItemActionButton}"
                                                        Content="&#xE74D;"
                                                        ToolTip="{Binding RemoveToolTip}"
                                                        Margin="2,0,0,0"
                                                        Click="RemoveItemButton_Click" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FFF8F8F8" />
                                        <Setter TargetName="GroupLayerBack" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="GroupLayerMid" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="BadgeSurface" Property="Background" Value="#FF141414" />
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="#FFFFFFFF" />
                                        <Setter TargetName="IconSurface" Property="Background" Value="#FFFFFFFF" />
                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Exists}" Value="False">
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FFF0F0F0" />
                                        <Setter TargetName="ItemNameText" Property="Foreground" Value="#FF696969" />
                                        <Setter TargetName="ItemPathText" Property="Foreground" Value="#FF8A8A8A" />
                                        <Setter TargetName="BadgeSurface" Property="Opacity" Value="0.55" />
                                        <Setter TargetName="IconSurface" Property="Opacity" Value="0.55" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Exists}" Value="True" />
                                            <Condition Binding="{Binding HasMissingPaths}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FFFFFAEE" />
                                        <Setter TargetName="MissingTextBlock" Property="Foreground" Value="#FF9B5B00" />
                                        <Setter TargetName="BadgeSurface" Property="Opacity" Value="0.78" />
                                        <Setter TargetName="IconSurface" Property="Opacity" Value="0.78" />
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding HasChangedPaths}" Value="True">
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FFFFFAEE" />
                                        <Setter TargetName="VersionTextBlock" Property="Foreground" Value="#FF9B5B00" />
                                        <Setter TargetName="BadgeSurface" Property="Opacity" Value="0.78" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FFF7F7F7" />
                                        <Setter TargetName="ActionPanel" Property="Opacity" Value="1" />
                                        <Setter TargetName="PinStatusText" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FF141414" />
                                        <Setter TargetName="BadgeSurface" Property="Background" Value="#FFFFFFFF" />
                                        <Setter TargetName="BadgeText" Property="Foreground" Value="#FF141414" />
                                        <Setter TargetName="IconSurface" Property="Background" Value="#FFFFFFFF" />
                                        <Setter TargetName="ItemNameText" Property="Foreground" Value="#FFFFFFFF" />
                                        <Setter TargetName="ItemPathText" Property="Foreground" Value="#FFE5E5E5" />
                                        <Setter TargetName="MissingTextBlock" Property="Foreground" Value="#FFFFE2E0" />
                                        <Setter TargetName="VersionTextBlock" Property="Foreground" Value="#FFFFE2E0" />
                                        <Setter TargetName="ActionPanel" Property="Opacity" Value="1" />
                                        <Setter TargetName="PinStatusText" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="PinItemButton" Property="Background" Value="#26FFFFFF" />
                                        <Setter TargetName="PinItemButton" Property="Foreground" Value="#FFFFFFFF" />
                                        <Setter TargetName="RevealItemButton" Property="Background" Value="#26FFFFFF" />
                                        <Setter TargetName="RevealItemButton" Property="Foreground" Value="#FFFFFFFF" />
                                        <Setter TargetName="RemoveItemButton" Property="Background" Value="#26FFFFFF" />
                                        <Setter TargetName="RemoveItemButton" Property="Foreground" Value="#FFFFFFFF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                        <Setter TargetName="PinItemButton" Property="Content" Value="&#xE77A;" />
                                        <Setter TargetName="PinItemButton" Property="Background" Value="#FF141414" />
                                        <Setter TargetName="PinItemButton" Property="Foreground" Value="#FFFFFFFF" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPinned}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="PinItemButton" Property="Background" Value="#26FFFFFF" />
                                        <Setter TargetName="PinItemButton" Property="Foreground" Value="#FFFFFFFF" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        </ListBox>
                        <Border x:Name="NoticeBar"
                                Grid.Row="0"
                                MinHeight="26"
                                Margin="12,0,12,10"
                                Padding="9,5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="#EE141414"
                                CornerRadius="8"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <TextBlock x:Name="NoticeTextBlock"
                                       FontSize="10"
                                       Foreground="#FFFFFFFF"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                        <Button x:Name="AddButton"
                                Grid.Row="1"
                                Width="48"
                                Height="24"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                Style="{StaticResource ShelfButton}"
                                Background="#10000000"
                                Foreground="#FF141414"
                                FontSize="15"
                                Padding="0"
                                Click="AddButton_Click" />
                    </Grid>
                </Border>

                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border x:Name="EmptyIconSurface"
                            Width="64"
                            Height="64"
                            Background="#FFFFFFFF"
                            BorderBrush="#FF141414"
                            BorderThickness="1"
                            CornerRadius="18">
                        <TextBlock x:Name="EmptyIconText"
                                   Text="&#xE896;"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="34"
                                   Foreground="#FF141414" />
                    </Border>
                    <TextBlock x:Name="EmptyTitleTextBlock"
                               Margin="0,12,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF141414"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptyHintTextBlock"
                               Margin="0,5,0,0"
                               FontSize="10"
                               Foreground="#FF4A4A4A"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="180" />
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
    <Canvas x:Name="DragHintLayer"
            IsHitTestVisible="False">
        <Border x:Name="DragHint"
                MaxWidth="220"
                Padding="8,5"
                Background="#EE141414"
                CornerRadius="8"
                Visibility="Collapsed">
            <TextBlock x:Name="DragHintTextBlock"
                       FontSize="10"
                       Foreground="#FFFFFFFF"
                       TextWrapping="Wrap" />
        </Border>
    </Canvas>
    </Grid>
</Window>
